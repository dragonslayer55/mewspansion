	major_class_checkmarks [caves boneyard moon core jurassic theend meatworld dimensionx endoftime]

	map_areas { //which save file flag needs to be checked for showing this area on the map
		alley departed_first_real_adventure
		sewers mapflag_SewersUnlocked
		junkyard mapflag_JunkyardUnlocked
		caves mapflag_CavesUnlocked
		boneyard mapflag_BoneyardUnlocked
		//meatworld mapflag_MeatWorldUnlocked
		meatworld mapflag_MeatWorldUnlockedFull

		desert mapflag_DesertUnlocked
		crater mapflag_CraterUnlocked
		bunker mapflag_BunkerUnlocked
		moon mapflag_MoonUnlocked
		core mapflag_CoreUnlocked
		dimensionx mapflag_DimensionXUnlocked

		lab mapflag_LabUnlocked
		iceage mapflag_IceAgeUnlocked
		future mapflag_FutureUnlocked
		jurassic mapflag_JurassicUnlocked
		theend mapflag_TheEndUnlocked
		endoftime mapflag_EndOfTimeUnlocked

		bossrush1 mapflag_TheEndUnlocked

		nuke PlotFlag_FrankBeanies //not a real area but wont show until this flag is set
	}

}

