        Trample 1
        KaijuKnockbackImmune 1
        DissuadeInstakills 1

        //ChanceToDisableActionsIfNotCharmed 75% //25% chance of actually attacking on any given turn, unless charmed/posessed/madness/etc
        BonusAbility ZaratanaSoloCrater
        
    

        ImmediateAbilityReaction {
            ability ZaratanaVSRevenge
            ability_damage_only true
            damage_threshold 10
        }

        FormChanger {
            Default {
                passives {
                    ImmediateAbilityReaction {
                        ability ZaratanaVSRevenge
                        ability_damage_only true
                        damage_threshold 10
                    }
                    BonusAbility ZaratanaSoloCrater
                }
                abilities {
                    move DefaultMove
                    attack ZaratanaSoloBasicMini
        
                    spells [
                        ZaratanaSoloMagnet
                        ZaratanaSoloBombardmentMini
                        ZaratanaSoloTurtle
                        ZaratanaSoloRoar
                        ZaratanaSoloSpinDash

                        ZaratanaVSRevenge
                        ZaratanaSoloWeatherRoar
                        ZaratanaVSExitTurtle
                    ]
                }
            }
            Turtled {
                attack None
                move None
                animation_suffix Turtle


                passives {
                    Brace 10
                    Conditional_BadRoll{
                        odds 50%

                        ConjureBonusAbility ZaratanaVSExitTurtle
                    } Else {
                        ConjureBonusAbility ZaratanaSoloSpinDash
                    }
                    BonusAbility ZaratanaSoloCrater
                }

                ai {
                    brain GenericBrain

                    pattern {
                        do **ZaratanaSoloSpinDash
                        do *ZaratanaVSExitTurtle
                    }
                    reset_pattern_on_formswitch true
                    stun_advances_pattern false
                }
            }
        }
    }
    
    ai {
        // brain DbgPlayerBrain
        brain GenericBrain


        fallback {
            do_priority [attack move]
        }


        decision_weights default
        move_weights stay_close

        fallback_advances_pattern true
        stun_advances_pattern true
    }
